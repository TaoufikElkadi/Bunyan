# =============================================================================
# Bunyan Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Lines marked [required] must be set for the app to function.
# Lines marked [optional] have sensible defaults or are only needed in production.
# Variables prefixed NEXT_PUBLIC_* are exposed to the browser.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (https://supabase.com/dashboard)
# -----------------------------------------------------------------------------

# [required] [public] Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# [required] [public] Supabase anonymous / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# [required] [server-only] Supabase service-role key (full DB access, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# -----------------------------------------------------------------------------
# Stripe (https://dashboard.stripe.com/apikeys)
# -----------------------------------------------------------------------------

# [required] [server-only] Stripe secret key
STRIPE_SECRET_KEY=sk_test_...

# [required] [public] Stripe publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# [required] [server-only] Stripe webhook signing secret (from `stripe listen` or dashboard)
STRIPE_WEBHOOK_SECRET=whsec_...

# -----------------------------------------------------------------------------
# Resend (https://resend.com/api-keys)
# -----------------------------------------------------------------------------

# [optional] [server-only] Resend API key for transactional email
# If not set, emails are skipped in development.
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# [required] [public] Base URL of the application (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Sentry (https://sentry.io)
# -----------------------------------------------------------------------------

# [optional] [public] Sentry DSN for error tracking
# If not set, Sentry is disabled.
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# [optional] [server-only] Sentry auth token for source map uploads
# Generate at: https://sentry.io/orgredirect/organizations/:orgslug/settings/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_...

# [optional] Sentry org and project (used during build for source map uploads)
SENTRY_ORG=bunyan
SENTRY_PROJECT=javascript-nextjs

# -----------------------------------------------------------------------------
# Upstash Redis (https://console.upstash.com)
# -----------------------------------------------------------------------------

# [optional] [server-only] Upstash Redis for distributed rate limiting
# If not set, falls back to in-memory rate limiting (single-instance only).
# Required for production on Vercel (serverless).
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# -----------------------------------------------------------------------------
# Cron Jobs
# -----------------------------------------------------------------------------

# [required in production] [server-only] Bearer token to authenticate cron requests
# Used by /api/cron/reconcile and /api/cron/member-stats
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here
